# Google Cloud Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/gcp-key.json

# Vertex AI
VERTEX_AI_LOCATION=us-central1
CHATBOT_MODEL_ID=chat-bison

# Vision API
VISION_API_KEY=your-vision-api-key

# BigQuery
BIGQUERY_DATASET=maintenance_ai
BIGQUERY_TABLE_PREDICTIONS=predictions
BIGQUERY_TABLE_ANALYTICS=analytics

# Cloud Storage
GCS_BUCKET=maintenance-ai-bucket
GCS_IMAGE_FOLDER=training_images

# Flask App
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here
PORT=5000

# Database
FIRESTORE_COLLECTION=maintenance_records

# Logging
LOG_LEVEL=INFO

# Autoaprendizaje
AUTO_LEARNING_ENABLED=True
MODEL_UPDATE_FREQUENCY=daily
